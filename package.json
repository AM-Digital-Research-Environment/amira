{
	"name": "wisski-dashboard",
	"version": "2.0.0",
	"private": true,
	"type": "module",
	"sideEffects": [
		"**/*.css",
		"**/app.css",
		"**/+layout.svelte",
		"**/service-worker.js"
	],
	"engines": {
		"node": "^20.19.0 || ^22.12.0 || >=24.0.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"dependencies": {
		"@lucide/svelte": "^1.8.0",
		"clsx": "^2.1.1",
		"echarts": "^6.0.0",
		"echarts-wordcloud": "^2.1.0",
		"maplibre-gl": "^5.22.0",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/eslint": "^9.6.1",
		"@types/node": "^25.5.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.8"
	},
	"overrides": {
		"@tailwindcss/vite": {
			"vite": "$vite"
		},
		"echarts-wordcloud": {
			"echarts": "$echarts"
		}
	}
}
